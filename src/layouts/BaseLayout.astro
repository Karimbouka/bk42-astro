---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { translations, localizedPath, otherLocale } from '../i18n';
import type { Locale, Translation } from '../i18n';

export interface Props {
  locale: Locale;
  pageKey: keyof Translation['routes'];
  title: string;
  description: string;
  /** dark = transparent nav over a dark hero (home, about). default false. */
  dark?: boolean;
}

const { locale, pageKey, title, description, dark = false } = Astro.props;
const t = translations[locale];

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const ogImage = new URL('/images/logo/bk42-horizontal.png', Astro.site).toString();
const altLocale = otherLocale(locale);
const altUrl = new URL(localizedPath(altLocale, pageKey), Astro.site).toString();
const xDefault = new URL(localizedPath('fr', pageKey), Astro.site).toString();
---
<!DOCTYPE html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1" />

    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang={locale === 'fr' ? 'fr-FR' : 'en-GB'} href={canonical} />
    <link rel="alternate" hreflang={altLocale === 'fr' ? 'fr-FR' : 'en-GB'} href={altUrl} />
    <link rel="alternate" hreflang="x-default" href={xDefault} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale === 'fr' ? 'fr_FR' : 'en_GB'} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />

    <link rel="icon" type="image/svg+xml" href="/images/logo/bk42-icon-only.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Montserrat:wght@400;500;600;700;800&family=Playfair+Display:ital,wght@0,500;0,600;0,700;0,800;1,500;1,600;1,700;1,800&display=swap"
    />

    <script type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'CarRental',
      name: 'BK42 Car Rental',
      url: 'https://bk42auto.com',
      logo: 'https://bk42auto.com/images/logo/bk42-horizontal.png',
      telephone: '+212706401827',
      email: 'bk42rentcars@gmail.com',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Lot ennour N56',
        addressLocality: 'Larache',
        addressCountry: 'MA',
      },
      areaServed: ['Larache', 'Tanger', 'Rabat', 'Casablanca', 'Marrakech'],
      sameAs: ['https://www.instagram.com/bk42_location_auto/'],
    })} />
  </head>
  <body>
    <Nav locale={locale} pageKey={pageKey} dark={dark} />
    <main>
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
