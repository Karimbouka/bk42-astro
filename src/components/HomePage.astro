---
import Hero from './Hero.astro';
import FeatureRow from './FeatureRow.astro';
import FleetCard from './FleetCard.astro';
import LocationReviews from './LocationReviews.astro';
import { translations, localizedPath } from '../i18n';
import { fleet } from '../data/fleet';
import type { Locale } from '../i18n';

export interface Props { locale: Locale }
const { locale } = Astro.props;
const t = translations[locale];
const featured = fleet.slice(0, 3);
---
<Hero locale={locale} />

<LocationReviews locale={locale} />

<section class="section section-light">
  <div class="container">
    <div style="display:flex; align-items:flex-end; justify-content:space-between; margin-bottom:48px; flex-wrap:wrap; gap:24px;">
      <div>
        <p class="eyebrow">{t.homeFleetEyebrow}</p>
        <h2 class="h2">{t.homeFleetHeadline}</h2>
      </div>
      <a href={localizedPath(locale, 'fleet')} style="font-family:var(--font-sans); font-size:13px; font-weight:600; letter-spacing:.16em; text-transform:uppercase; color:var(--bk-gold-600);">{t.homeViewAll}</a>
    </div>
    <div class="fleet-grid">
      {featured.map((car) => <FleetCard car={car} locale={locale} />)}
    </div>
  </div>
</section>

<FeatureRow locale={locale} />

<section class="section section-dark">
  <div class="container two-col-center">
    <div>
      <p class="eyebrow dark">{t.homeTaglineEyebrow}</p>
      <h2 class="tagline-quote">{t.homeTaglineQuote}</h2>
      <p class="tagline-body">{t.homeTaglineBody}</p>
      <a href={localizedPath(locale, 'booking')} class="btn btn-on-dark-gold">{t.homeBookCta} →</a>
    </div>
    <div class="brackets" style="padding:32px;">
      <span class="br-tr"></span><span class="br-bl"></span>
      <div class="fortytwo-card">
        <div class="fortytwo">42</div>
        <div class="fortytwo-label">{t.homeLuckyNum}</div>
      </div>
    </div>
  </div>
</section>
