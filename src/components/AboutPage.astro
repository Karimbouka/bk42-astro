---
import { translations } from '../i18n';
import type { Locale } from '../i18n';

export interface Props { locale: Locale }
const { locale } = Astro.props;
const t = translations[locale];
---
<section class="section section-dark">
  <div class="container" style="max-width:900px;">
    <p class="eyebrow dark">{t.aboutEyebrow}</p>
    <h1 class="h1" style="font-size:clamp(44px, 6vw, 84px);">{t.aboutHeadline}</h1>
    <p class="lead">{t.aboutSub}</p>
  </div>
</section>

<section class="section section-light" style="padding:96px 0;">
  <div class="container two-col">
    <div>
      <p class="eyebrow">{t.aboutApproachEyebrow}</p>
      <h2 class="h3">{t.aboutApproachTitle}</h2>
      <p class="body">{t.aboutApproachBody}</p>
    </div>
    <div>
      <p class="eyebrow">{t.aboutCommitEyebrow}</p>
      <h2 class="h3">{t.aboutCommitTitle}</h2>
      <p class="body">{t.aboutCommitBody}</p>
    </div>
  </div>
</section>
